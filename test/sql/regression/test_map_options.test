# name: test/sql/regression/test_map_options.test
# description: Test new MAP options: solver, hc_type, lambda_scaling, glm_lambda
# group: [regression]

require anofox_statistics

# =============================================================================
# SETUP: Create regression data
# =============================================================================

statement ok
CREATE TABLE reg_data AS
SELECT * FROM (VALUES
    (1.0, 2.1, 10.5, 1.0),
    (2.0, 3.2, 15.8, 2.0),
    (3.0, 4.1, 20.2, 1.5),
    (4.0, 5.3, 26.1, 2.5),
    (5.0, 6.2, 30.5, 1.0),
    (6.0, 7.1, 35.8, 3.0),
    (7.0, 8.4, 41.2, 2.0),
    (8.0, 9.2, 46.0, 1.5),
    (9.0, 10.3, 51.5, 2.5),
    (10.0, 11.1, 56.2, 2.0)
) AS t(x1, x2, y, w);

# Count data for Poisson tests
statement ok
CREATE TABLE count_data AS
SELECT * FROM (VALUES
    (1.0, 2.0, 5),
    (2.0, 3.0, 8),
    (3.0, 4.0, 12),
    (4.0, 5.0, 18),
    (5.0, 6.0, 25),
    (6.0, 7.0, 33),
    (7.0, 8.0, 42),
    (8.0, 9.0, 55),
    (9.0, 10.0, 70),
    (10.0, 11.0, 90)
) AS t(x1, x2, y);

# =============================================================================
# OLS: solver option
# =============================================================================

# TEST: OLS with SVD solver (default)
query I
SELECT (ols_fit_agg(y, [x1, x2], {'solver': 'svd'})).r_squared IS NOT NULL FROM reg_data;
----
true

# TEST: OLS with QR solver
query I
SELECT (ols_fit_agg(y, [x1, x2], {'solver': 'qr'})).r_squared IS NOT NULL FROM reg_data;
----
true

# TEST: OLS with Cholesky solver
query I
SELECT (ols_fit_agg(y, [x1, x2], {'solver': 'cholesky'})).r_squared IS NOT NULL FROM reg_data;
----
true

# TEST: All OLS solvers produce similar R-squared
query I
SELECT abs(
    (SELECT (ols_fit_agg(y, [x1, x2], {'solver': 'svd'})).r_squared FROM reg_data) -
    (SELECT (ols_fit_agg(y, [x1, x2], {'solver': 'qr'})).r_squared FROM reg_data)
) < 1e-10;
----
true

query I
SELECT abs(
    (SELECT (ols_fit_agg(y, [x1, x2], {'solver': 'svd'})).r_squared FROM reg_data) -
    (SELECT (ols_fit_agg(y, [x1, x2], {'solver': 'cholesky'})).r_squared FROM reg_data)
) < 1e-10;
----
true

# TEST: Invalid solver raises error
statement error
SELECT ols_fit_agg(y, [x1, x2], {'solver': 'invalid'}) FROM reg_data;
----
Invalid solver

# =============================================================================
# OLS: hc_type option
# =============================================================================

# TEST: OLS with HC0 standard errors
query I
SELECT (ols_fit_agg(y, [x1, x2], {'compute_inference': true, 'hc_type': 'hc0'})).std_errors IS NOT NULL FROM reg_data;
----
true

# TEST: OLS with HC1 standard errors
query I
SELECT (ols_fit_agg(y, [x1, x2], {'compute_inference': true, 'hc_type': 'hc1'})).std_errors IS NOT NULL FROM reg_data;
----
true

# TEST: OLS with HC2 standard errors
query I
SELECT (ols_fit_agg(y, [x1, x2], {'compute_inference': true, 'hc_type': 'hc2'})).std_errors IS NOT NULL FROM reg_data;
----
true

# TEST: OLS with HC3 standard errors
query I
SELECT (ols_fit_agg(y, [x1, x2], {'compute_inference': true, 'hc_type': 'hc3'})).std_errors IS NOT NULL FROM reg_data;
----
true

# TEST: OLS with hc_type='none' (classical SEs) - same as default
query I
SELECT (ols_fit_agg(y, [x1, x2], {'compute_inference': true, 'hc_type': 'none'})).std_errors IS NOT NULL FROM reg_data;
----
true

# TEST: Invalid hc_type raises error
statement error
SELECT ols_fit_agg(y, [x1, x2], {'hc_type': 'hc4'}) FROM reg_data;
----
Invalid hc_type

# TEST: OLS combining solver + hc_type
query I
SELECT (ols_fit_agg(y, [x1, x2], {'solver': 'qr', 'hc_type': 'hc3', 'compute_inference': true})).p_values IS NOT NULL FROM reg_data;
----
true

# =============================================================================
# WLS: solver + hc_type options
# =============================================================================

# TEST: WLS with QR solver
query I
SELECT (wls_fit_agg(y, [x1, x2], w, {'solver': 'qr'})).r_squared IS NOT NULL FROM reg_data;
----
true

# TEST: WLS with Cholesky solver
query I
SELECT (wls_fit_agg(y, [x1, x2], w, {'solver': 'cholesky'})).r_squared IS NOT NULL FROM reg_data;
----
true

# TEST: WLS with HC1 standard errors
query I
SELECT (wls_fit_agg(y, [x1, x2], w, {'compute_inference': true, 'hc_type': 'hc1'})).std_errors IS NOT NULL FROM reg_data;
----
true

# TEST: WLS combining solver + hc_type
query I
SELECT (wls_fit_agg(y, [x1, x2], w, {'solver': 'qr', 'hc_type': 'hc3', 'compute_inference': true})).p_values IS NOT NULL FROM reg_data;
----
true

# =============================================================================
# Ridge: solver + lambda_scaling options
# =============================================================================

# TEST: Ridge with QR solver
query I
SELECT (ridge_fit_agg(y, [x1, x2], {'alpha': 0.1, 'solver': 'qr'})).r_squared IS NOT NULL FROM reg_data;
----
true

# TEST: Ridge with Cholesky solver
query I
SELECT (ridge_fit_agg(y, [x1, x2], {'alpha': 0.1, 'solver': 'cholesky'})).r_squared IS NOT NULL FROM reg_data;
----
true

# TEST: Ridge with glmnet lambda scaling
query I
SELECT (ridge_fit_agg(y, [x1, x2], {'alpha': 0.1, 'lambda_scaling': 'glmnet'})).r_squared IS NOT NULL FROM reg_data;
----
true

# TEST: Ridge with raw lambda scaling (default)
query I
SELECT (ridge_fit_agg(y, [x1, x2], {'alpha': 0.1, 'lambda_scaling': 'raw'})).r_squared IS NOT NULL FROM reg_data;
----
true

# TEST: Ridge combining solver + lambda_scaling
query I
SELECT (ridge_fit_agg(y, [x1, x2], {'alpha': 0.1, 'solver': 'cholesky', 'lambda_scaling': 'glmnet'})).r_squared IS NOT NULL FROM reg_data;
----
true

# TEST: Invalid lambda_scaling raises error
statement error
SELECT ridge_fit_agg(y, [x1, x2], {'alpha': 0.1, 'lambda_scaling': 'invalid'}) FROM reg_data;
----
Invalid lambda_scaling

# TEST: Ridge all solvers produce similar results with same scaling
query I
SELECT abs(
    (SELECT (ridge_fit_agg(y, [x1, x2], {'alpha': 0.1, 'solver': 'svd'})).r_squared FROM reg_data) -
    (SELECT (ridge_fit_agg(y, [x1, x2], {'alpha': 0.1, 'solver': 'qr'})).r_squared FROM reg_data)
) < 1e-10;
----
true

# TEST: Ridge glmnet vs raw scaling produce different results (different conventions)
query I
SELECT
    (SELECT (ridge_fit_agg(y, [x1, x2], {'alpha': 1.0, 'lambda_scaling': 'glmnet'})).r_squared FROM reg_data) !=
    (SELECT (ridge_fit_agg(y, [x1, x2], {'alpha': 1.0, 'lambda_scaling': 'raw'})).r_squared FROM reg_data);
----
true

# =============================================================================
# ElasticNet: lambda_scaling option
# =============================================================================

# TEST: ElasticNet with glmnet scaling
query I
SELECT (elasticnet_fit_agg(y, [x1, x2], {'alpha': 0.1, 'l1_ratio': 0.5, 'lambda_scaling': 'glmnet'})).r_squared IS NOT NULL FROM reg_data;
----
true

# TEST: ElasticNet with raw scaling (default)
query I
SELECT (elasticnet_fit_agg(y, [x1, x2], {'alpha': 0.1, 'l1_ratio': 0.5, 'lambda_scaling': 'raw'})).r_squared IS NOT NULL FROM reg_data;
----
true

# TEST: ElasticNet glmnet vs raw scaling produce different results
query I
SELECT
    (SELECT (elasticnet_fit_agg(y, [x1, x2], {'alpha': 1.0, 'l1_ratio': 0.5, 'lambda_scaling': 'glmnet'})).r_squared FROM reg_data) !=
    (SELECT (elasticnet_fit_agg(y, [x1, x2], {'alpha': 1.0, 'l1_ratio': 0.5, 'lambda_scaling': 'raw'})).r_squared FROM reg_data);
----
true

# =============================================================================
# Poisson: glm_lambda option
# =============================================================================

# TEST: Poisson with no regularization (default)
query I
SELECT (poisson_fit_agg(y, [x1, x2], {'glm_lambda': 0.0})).pseudo_r_squared IS NOT NULL FROM count_data;
----
true

# TEST: Poisson with L2 regularization
query I
SELECT (poisson_fit_agg(y, [x1, x2], {'glm_lambda': 0.01})).pseudo_r_squared IS NOT NULL FROM count_data;
----
true

# TEST: Poisson with larger regularization
query I
SELECT (poisson_fit_agg(y, [x1, x2], {'glm_lambda': 1.0})).pseudo_r_squared IS NOT NULL FROM count_data;
----
true

# TEST: Poisson regularization changes coefficients
query I
SELECT
    (SELECT (poisson_fit_agg(y, [x1, x2], {'glm_lambda': 0.0})).coefficients[1] FROM count_data) !=
    (SELECT (poisson_fit_agg(y, [x1, x2], {'glm_lambda': 1.0})).coefficients[1] FROM count_data);
----
true

# TEST: Poisson combining glm_lambda with other options
query I
SELECT (poisson_fit_agg(y, [x1, x2], {'glm_lambda': 0.01, 'compute_inference': true, 'link': 'log'})).std_errors IS NOT NULL FROM count_data;
----
true

# =============================================================================
# Window functions: solver option propagation
# =============================================================================

# TEST: ols_fit_predict with solver
query I
SELECT count(*) > 0 FROM (
    SELECT (ols_fit_predict(y, [x1, x2], {'solver': 'qr'}) OVER ()).yhat
    FROM reg_data
);
----
true

# TEST: ridge_fit_predict with solver + lambda_scaling
query I
SELECT count(*) > 0 FROM (
    SELECT (ridge_fit_predict(y, [x1, x2], {'alpha': 0.1, 'solver': 'cholesky', 'lambda_scaling': 'glmnet'}) OVER ()).yhat
    FROM reg_data
);
----
true

# =============================================================================
# Predict aggregate functions: solver option propagation
# =============================================================================

# TEST: ols_fit_predict_agg with solver
query I
SELECT (ols_fit_predict_agg(y, [x1, x2], {'solver': 'qr'}))[1].yhat IS NOT NULL FROM reg_data;
----
true

# TEST: ridge_fit_predict_agg with solver + lambda_scaling
query I
SELECT (ridge_fit_predict_agg(y, [x1, x2], {'alpha': 0.1, 'solver': 'cholesky', 'lambda_scaling': 'glmnet'}))[1].yhat IS NOT NULL FROM reg_data;
----
true

# =============================================================================
# Case-insensitive key matching
# =============================================================================

# TEST: solver key is case-insensitive (value is lowered)
query I
SELECT (ols_fit_agg(y, [x1, x2], {'solver': 'SVD'})).r_squared IS NOT NULL FROM reg_data;
----
true

query I
SELECT (ols_fit_agg(y, [x1, x2], {'solver': 'Qr'})).r_squared IS NOT NULL FROM reg_data;
----
true

# =============================================================================
# STRUCT syntax (DuckDB sometimes uses STRUCT instead of MAP)
# =============================================================================

# TEST: STRUCT-style options work for solver
query I
SELECT (ols_fit_agg(y, [x1, x2], {solver: 'qr'})).r_squared IS NOT NULL FROM reg_data;
----
true

# TEST: STRUCT-style options work for lambda_scaling
query I
SELECT (ridge_fit_agg(y, [x1, x2], {alpha: 0.1, lambda_scaling: 'glmnet'})).r_squared IS NOT NULL FROM reg_data;
----
true

# =============================================================================
# Cleanup
# =============================================================================

statement ok
DROP TABLE reg_data;

statement ok
DROP TABLE count_data;
